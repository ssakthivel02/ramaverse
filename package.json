    "expo-speech": "~13.0.0",
    "expo-splash-screen": "~0.29.0",
    "expo-sqlite": "~15.0.0",
    "firebase": "^10.12.0",
    "i18next": "^23.11.0",
    "react": "18.3.1",
    "react-dom": "^18.3.1",
